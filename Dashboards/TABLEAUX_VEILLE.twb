            <column datatype='string' name='[Jour]' role='dimension' type='nominal' />
            <column datatype='string' name='[Semaine]' role='dimension' type='nominal' />
            <column-instance column='[Jour]' derivation='None' name='[none:Jour:nk]' pivot='key' type='nominal' />
            <column-instance column='[Semaine]' derivation='None' name='[none:Semaine:nk]' pivot='key' type='nominal' />
            <column-instance column='[Intensite]' derivation='Sum' name='[sum:Intensite:qk]' pivot='key' type='quantitative' />
